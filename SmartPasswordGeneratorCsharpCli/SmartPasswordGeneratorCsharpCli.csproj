<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AssemblyName>SmartPasswordGeneratorCsharpCli</AssemblyName>
		<RootNamespace>SmartPasswordGeneratorCsharpCli</RootNamespace>

		<Version>4.0.0</Version>
		<Company>Alexander Suvorov</Company>
		<Product>SMART PASSWORD GENERATOR (C#) CLI</Product>
		<Copyright>BSD 3-Clause License</Copyright>
		<Description>Terminal-based smart password generator with deterministic password generation. Generate passwords from secret phrases - same secret always produces the same password, no storage required. All from your command line.</Description>
		<RepositoryUrl>https://github.com/smartlegionlab/SmartPasswordGeneratorCsharpCli</RepositoryUrl>

		<PublishSingleFile>true</PublishSingleFile>
		<SelfContained>true</SelfContained>
		<PublishTrimmed>false</PublishTrimmed>
	</PropertyGroup>

</Project>